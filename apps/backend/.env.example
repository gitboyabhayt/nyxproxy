# NyxProxy backend environment.
# Set whichever provider keys you have — any single one is enough to start.

# Which provider is used when the client does not specify one explicitly.
NYXPROXY_DEFAULT_PROVIDER=groq

# CORS — comma separated list of allowed origins, or "*".
NYXPROXY_ALLOWED_ORIGINS=*

# Optional shared secret. If set, clients must send `Authorization: Bearer <token>`.
NYXPROXY_API_TOKEN=

# Per-provider keys (all optional).
GROQ_API_KEY=
OPENROUTER_API_KEY=
HF_TOKEN=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
GITHUB_MODELS_TOKEN=
NVIDIA_API_KEY=
BYTEZ_API_KEY=
GEMINI_API_KEY=

# Ollama (local) — usually http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434
