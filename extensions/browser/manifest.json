{
  "manifest_version": 3,
  "name": "Send to NyxProxy",
  "version": "0.1.0",
  "description": "Right-click any page or link to send it to NyxProxy for capture and analysis.",
  "permissions": ["contextMenus", "activeTab", "storage", "notifications"],
  "host_permissions": ["http://127.0.0.1:8090/*"],
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Send current tab to NyxProxy",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
